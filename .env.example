# --- Backend API (required for app features that call your API) ---
# Exposed to the browser in Next.js — must use the NEXT_PUBLIC_ prefix.
# Use the origin where your API is served (port/path as in your backend).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/

# --- Figma (optional — only if you use Figma OAuth in this project) ---
# Create an app at https://www.figma.com/developers/apps
FIGMA_CLIENT_ID=your_figma_oauth_client_id
FIGMA_CLIENT_SECRET=your_figma_oauth_client_secret
